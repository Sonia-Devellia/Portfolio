RewriteEngine On

# ─── HTTPS forcé (commenté en local, à activer en prod) ─────────
# RewriteCond %{HTTPS} off
# RewriteCond %{HTTP:X-Forwarded-Proto} !https
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── www → apex (à activer en prod si voulu) ────────────────────
# RewriteCond %{HTTP_HOST} ^www\.sonia-habibi\.dev$ [NC]
# RewriteRule ^(.*)$ https://sonia-habibi.dev/$1 [L,R=301]

# ─── 301 — anciennes pages géo retirées ─────────────────────────
# Anglet est limitrophe de Biarritz → redirection thématique pertinente.
# Caen, Rouen, Le Havre, Lyon → homepage (pas de match équivalent).
RewriteRule ^dev-freelance/anglet/?$ /dev-freelance/biarritz [L,R=301,NE]
RewriteRule ^dev-freelance/(caen|rouen|le-havre|lyon)/?$ / [L,R=301,NE]

# ─── Sitemap dynamique : toujours via PHP, même si un fichier statique existe ─
RewriteRule ^sitemap\.xml$ index.php [L]

# ─── Routing front-controller ───────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ─── Hardening ──────────────────────────────────────────────────
Options -Indexes -MultiViews
ServerSignature Off

<IfModule mod_php.c>
    php_flag expose_php Off
</IfModule>

# ─── Fichiers sensibles ─────────────────────────────────────────
<FilesMatch "^(\.env|\.env\..+|\.git.*|\.htpasswd|composer\.(json|lock)|package(-lock)?\.json|skills-lock\.json|README\.md|CLAUDE\.md|AGENTS\.md|PRODUCT\.md|DESIGN\.(md|json))$|\.(scss|sql|log)$|\.config\.js$">
    Require all denied
</FilesMatch>

# ─── Dossiers internes (au cas où DocumentRoot mal configuré) ───
RewriteRule ^(app|core|config|lang|vendor|node_modules|storage|scss|tests|\.claude|\.superpowers|\.agents)(/|$) - [F,L]

# ─── Cache statique long ────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp                "access plus 1 year"
    ExpiresByType image/avif                "access plus 1 year"
    ExpiresByType image/jpeg                "access plus 1 year"
    ExpiresByType image/png                 "access plus 1 year"
    ExpiresByType image/svg+xml             "access plus 1 year"
    ExpiresByType image/x-icon              "access plus 1 year"
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType font/woff                 "access plus 1 year"
    ExpiresByType font/woff2                "access plus 1 year"
</IfModule>

# ─── Compression gzip ──────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml
</IfModule>
