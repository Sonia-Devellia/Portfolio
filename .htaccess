# Garde-fou : si le DocumentRoot prod pointe sur la racine du projet au lieu de
# /public, tout est refusé sauf /public. Le routing officiel passe par public/.htaccess.

RewriteEngine On

# En prod : décommenter pour forcer le passage par /public
# RewriteCond %{REQUEST_URI} !^/public(/|$)
# RewriteRule ^.*$ - [F,L]

Options -Indexes -MultiViews

<FilesMatch "^(\.env|\.env\..+|\.git.*|\.htpasswd|composer\.(json|lock)|package(-lock)?\.json|skills-lock\.json|README\.md|CLAUDE\.md|AGENTS\.md|PRODUCT\.md|DESIGN\.(md|json))$">
    Require all denied
</FilesMatch>
