### Application
APP_NAME="Portfolio Sonia Habibi"
APP_URL=http://localhost:8888/portfolio/public
APP_ENV=local
# APP_ENV=production en prod — déclenche : masquage erreurs PHP,
# HSTS header, cookie session secure, masquage message PDO,
# CSP upgrade-insecure-requests.

DEFAULT_LANG=fr

### Base de données
DB_HOST=127.0.0.1
DB_PORT=3306
# MAMP utilise généralement le port 8889 — sur OVH mutualisé, 3306 par défaut.
DB_NAME=portfolio
DB_USER=root
DB_PASS=

### Mail — formulaire contact
# ─── En local : laisser MAIL_HOST/MAIL_USER/MAIL_PASS vides ──────
# → fallback automatique sur mail() natif (qui ne livre généralement pas, mais ne casse pas).
#
# ─── En prod sur OVH mutualisé : SMTP authentifié ───────────────
# OVH SMTP recommandé :
#   MAIL_HOST=ssl0.ovh.net
#   MAIL_PORT=465          (SSL/TLS — recommandé)
#   MAIL_PORT=587          (STARTTLS — alternative si 465 bloqué)
#   MAIL_USER=contact@sonia-habibi.dev     (email complet du compte OVH)
#   MAIL_PASS=••••••••     (mot de passe du compte mail, pas du compte OVH)
#
# IMPORTANT : MAIL_FROM doit appartenir au domaine OVH pour que SPF/DKIM s'alignent.
# Sans alignement, les emails partent en spam même avec SMTP authentifié.

MAIL_FROM=contact@sonia-habibi.dev
MAIL_TO=sonia@sonia-habibi.dev
MAIL_HOST=
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=

### Admin
# Générer le hash :
#   php -r "echo password_hash('votre_mot_de_passe', PASSWORD_DEFAULT) . PHP_EOL;"
# IMPORTANT : générer un nouveau hash pour la prod, différent du dev.
ADMIN_USER=admin
ADMIN_PASS_HASH=
